{
  "name": "roboticdub",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:css": "postcss css/style.css -o css/style.min.css",
    "build:js:main": "terser js/main.js -o js/main.min.js -c -m",
    "build:js:player": "terser js/player.js -o js/player.min.js -c -m",
    "build:js:disco": "terser js/discography.js -o js/discography.min.js -c -m",
    "build:js": "npm-run-all build:js:*",
    "build:html": "node scripts/optimize_html.js",
    "build": "npm-run-all build:css build:js build:html"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "terser": "^5.46.1"
  }
}
